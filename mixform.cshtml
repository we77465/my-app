    string docnogen(string yymm, string brno, string hasdocno)
    {
        string docno0 = yymm + brno + "01";
        string olddocno = yymm + brno + "00";
        try
        {
            SqlConnection con = new SqlConnection()
            {
                ConnectionString = Configuration["ConnectionStrings:bee"]
            };
            con.Open();
            // var json = string.Empty;
            //if (Request.Query.Count > 0)
            {
                var insert = new SqlCommand("select max(docno) as docno from bee.dbo.tips where docno like @docno", con);
                insert.Parameters.Add(new SqlParameter("docno", yymm + brno + "%"));
                var reader = insert.ExecuteReader();

                if (reader.HasRows)
                {
                    DataTable result = new DataTable();
                    result.Load(reader);
                    if (result.Rows.Count > 0)
                    {
                        olddocno = result.Rows[0][0].ToString();
                    }
                }
                reader.Close();
            }
            con.Close();
        }
        catch (Exception)
        {
        }
        if (string.Compare(olddocno, docno0) != -1)
        {
            int DocNoNo = Convert.ToInt32(olddocno.Substring(olddocno.Length - 2, 2)) + 1;
            if (hasdocno == "1")
            {
                docno0 = olddocno;
            }
            else
            {
                docno0 = yymm + brno + DocNoNo.ToString("00");
            }
        }
        return docno0;
    }
