@page
@using Microsoft.Extensions.Configuration
@using Microsoft.AspNetCore.Hosting
@inject IConfiguration Configuration
@inject IWebHostEnvironment WebHostEnvironment
@using Microsoft.Data.SqlClient
@using System.Collections.Generic
@using System.Text.Json
@using System.Text.Json.Nodes
@using System;
@using System.Net;
@using System.Net.Http;
@using System.IO;
@using System.Data
@using System.Net.Sockets;
@using Microsoft.AspNetCore.Http.Extensions;
@{
    ViewBag.Request = Request;
    ViewBag.ParentViewBag = ViewBag;

}

@{
    string url = HttpContext.Request.GetDisplayUrl();
    var uri = url.Split("/");
    string env = "official";
    ViewBag.env = "official";
    if (uri[2] == "inapt02.intra.chb.com.tw" || uri[2] == "localhost:5124" || uri[2] == "localhost:7124")
    {
        env = "test";//這幾個網域設為測試環境
        ViewBag.env = "test";
    }
    if (Request.Headers["User-Agent"].ToString().Contains("MSIE"))
    {
        WriteLiteral("應用程式未相容於IE，請使用Chrome");
        return;
    }

    if (Request.ContentLength > 0)
    {
        ViewBag.docno = Request.Form["docno"];
        ViewBag.ver = Request.Form["fintechver"];
    }
    else
    {
        ViewBag.docno = Request.Query.ContainsKey("docno") ? Request.Query["docno"].ToString() : ViewBag.docno;
    }
    var who = GetSSONo(Request.Query);

    ViewBag.ubrno = who["OU_ID"].PadRight(6, '0').Substring(0, 6);
    ViewBag.uid = who["USR_ID"];
    ViewBag.famin = who["FAMIN"];   //判斷是否為發明人
    ViewBag.sign = "N"; //是否在放行狀態

    string truepath = @WebHostEnvironment.ContentRootPath;
    truepath = truepath.Replace("DotNet6", "UpLoad\\chb01\\" + ViewBag.docno);
    var fesip = "ftp://10.100.61.67";
    var ap2ip = "ftp://inap02.intra.chb.com.tw";
    NetworkCredential fes = new NetworkCredential("TIPS", "tips@CHB");
    NetworkCredential ap2 = new NetworkCredential("dwintra", "iPhone6");
}
@{
    ViewBag._checks = string.Empty;
    if (Request.ContentLength > 0)
    {
        await Html.PartialAsync("_checks.cshtml"); //檢核某些必填項目
    }
}
@{
    if (env == "test")//如果是測試環境，換成測試ip
    {
        fesip = "ftp://10.100.71.64";//FES
        ap2ip = "ftp://10.100.7.188";//內網AP2
        fes = new NetworkCredential("intrauser", "intrauser@CHB");
    }

    var feschb01 = fesip + "/OutUFTP/chb01/";
    var fesnp01 = fesip + "/OutUFTP/np01/"; //連邦
    var fesp01 = fesip + "/OutUFTP/YIPO/"; //育晟
    var ap2ftp = ap2ip + "/IntraWeb/UpLoad/chb01/";
    if (env == "test")
    {
        fesp01 = fesip + "/OutUFTP/p01/"; //測試環境育晟目錄是p01
    }
    // ViewBag.docno = DateTime.Now.ToString("yyyyMMdd") + ViewBag.ubrno + "01";
    if (Request.ContentLength > 0)
    {
        // ViewBag.docno = docnogen(DateTime.Now.ToString("yyyyMMdd"), ViewBag.ubrno,"1");
        //ViewBag.docno = Request.Form["docno"];
    }
    else
    {
        ViewBag.docno = docnogen(DateTime.Now.ToString("yyyyMMdd"), ViewBag.ubrno, "0");
    }

    ViewBag.docno = Request.Query.ContainsKey("docno") ? Request.Query["docno"].ToString() : ViewBag.docno;


    List<Dictionary<string, string>> dSysTextJson = getData();
    var log = GettblLog(ViewBag.docno);//取得狀態

    ViewBag.Status = "issue";   //目前狀態，決定資料是否能修改用

    var data = select(dSysTextJson[0]);
    foreach (var d in data)
    {
        foreach (var id in d)
        {
            if (dSysTextJson[0].ContainsKey(id.Key))
            {
                dSysTextJson[0][id.Key] = id.Value;
            }
            else
            {
                dSysTextJson[0].Add(id.Key, id.Value);
            }
        }
    }

    ViewBag.data = dSysTextJson;
    ViewBag._approvable = string.Empty;
    await Html.PartialAsync("_approvable.cshtml");
    var _ViewBag = ViewBag.ParentViewBag;
    var approvableMsg = string.Empty;
    truepath = @WebHostEnvironment.ContentRootPath;
    truepath = truepath.Replace("DotNet6", "UpLoad\\chb01\\" + _ViewBag.docno);

    if (Request.ContentLength > 0)
    {
        switch (Request.Form["hHtml"].ToString())
        {
            //case "送簽": UpdateOrInsert(Request.Form); ReadySign(Request.Form); break;
            //case "退回": ReadySign(Request.Form); break;
            case "儲存":
                {
                    // if(checkError()==false)
                    // {
                    if (log.Count == 0 || log["_issue"].ToString() == "-2")//新提案資料庫沒有所以log.Count=0，已經儲存過但還沒有送負責人核可log["_issue"]=-2
                    {
                        UpdateOrInsert(Request.Form);
                        who = GetSSONo(Request.Query);
                        ViewBag.famin = who["FAMIN"];
                    }
                    else
                        Update(Request.Form);
                    // }
                    break;
                }
            case "儲存並送負責人核可":
                {
                    var file = Request.Form.Files;

                    foreach (var f in file)
                    {
                        FileUpload(f, truepath);
                    }
                    await Html.PartialAsync("_approvable.cshtml");
                    if (checkError() == false && string.IsNullOrEmpty(ViewBag._checks))
                    {
                        ReadySign(Request.Form);
                    }
                    else
                    {
                        if (log.Count == 0 || log["_issue"].ToString() == "-2")
                            UpdateOrInsert(Request.Form);
                        else
                            Update(Request.Form);
                    }
                    break;
                }
            case "送主管核可":
            case "放行":
                {
                    if (log["_issue"] == "3" && log["_rd"] == "1")//【研發】負責人放行時，判斷使否有確實填寫檔案取得時間，若無請退回經辦
                    {
                        Update(Request.Form);
                        if (checkError() == false)
                        {
                            ReadySign(Request.Form);
                        }
                    }
                    else if (log["_issue"] == "1")//【發想】負責人放行時，判斷使否有確實填寫檔案取得時間，若無請退回經辦
                    {
                        if (checkError() == false)
                        {
                            ReadySign(Request.Form);
                        }
                    }
                    else if (log["_proposal"] == "1")//【提案】負責人放行時，判斷使否有確實填寫檔案取得時間，若無請退回經辦
                    {
                        if (checkError() == false)
                        {
                            ReadySign(Request.Form);
                        }
                    }
                    else if (log["_proposal"] == "3" && log["FlowStatus"] == "1")//【申請/審核/領證】負責人放行時，判斷使否有確實填寫檔案取得時間，若無請退回經辦
                    {
                        if (checkError() == false)
                        {
                            ReadySign(Request.Form);
                        }
                    }
                    else
                    {
                        if (log["_proposal"] == "2") //【提案】會選擇往來事務所，經主管放行後，事務所才能在fes看到所屬案件的交換檔案
                        {
                            if (toFES(Request.Form))
                                ReadySign(Request.Form);
                        }
                        else
                        {
                            ReadySign(Request.Form);
                        }
                    }
                }// save to db
                break;
            case "退回修改": ReadySign(Request.Form); break;
            case "刪除": ReadySign(Request.Form); break;
            case "新增一筆": newLine(Request.Form, "Add"); Update(Request.Form); break;
            case "刪除一筆": newLine(Request.Form, "Del"); Update(Request.Form); break;    //20240410 數金處 薛伃庭 研發說明新增刪除一筆功能
            default: break;
        }

        var p01 = "0";

        if (log["_proposal"] == "3") //【申請/審核/領證】，發明人上傳之檔案無須主管放行，事務所即可於fes上看到
        {
            if (Request.Form.ContainsKey("專利事務所"))
            {
                if (Request.Form["專利事務所"] == "育晟")
                    p01 = fesp01;
                else if (Request.Form["專利事務所"] == "連邦")
                    p01 = fesnp01;
            }
        }
        var files = Request.Form.Files;

        foreach (var f in files)
        {
            if (p01 != "0")
                upDoc(f, fes, p01);
            if (env == "test")  //測試環境多傳chb01
                upDoc(f, fes, feschb01);
            //upDoc(f, ap2, ap2ftp);
            FileUpload(f, truepath);
        }

    }

    data = select(dSysTextJson[0]);
    foreach (var d in data)
    {
        foreach (var id in d)
        {
            if (dSysTextJson[0].ContainsKey(id.Key))
            {
                dSysTextJson[0][id.Key] = id.Value;
            }
            else
            {
                dSysTextJson[0].Add(id.Key, id.Value);
            }
        }
    }

    ViewBag.data = dSysTextJson;
    ViewBag.rdLine = string.IsNullOrEmpty(ViewBag.rdLine) ? ViewBag.data[0]["研發說明筆數"] : ViewBag.rdLine;
    ViewBag.ver = ViewBag.data[0].ContainsKey("fintechver") ? ViewBag.data[0]["fintechver"] : "0";

    var mfs = "-2-2-2-2-2";
    if (log.Count != 0)
    {
        mfs = log["_issue"] + log["_rd"] + log["_proposal"] + log["FlowStatus"] + log["_pay"];

        if (ViewBag.ver == "1") //新版研發跟提案合併
        {
            //目前狀態，決定資料是否能修改用，預設為issue
            if (log["FlowStatus"].ToString() == "3" || log["FlowStatus"].ToString() == "2" || log["FlowStatus"].ToString() == "1")
                ViewBag.Status = "end";
            else if ((log["_rd"].ToString() == "3" && log["_proposal"].ToString() == "3")
            || (log["_rd"].ToString() == "2" && log["_proposal"].ToString() == "2")
            || (log["_rd"].ToString() == "1" && log["_proposal"].ToString() == "1"))
                ViewBag.Status = "apply";
            else if (log["_issue"].ToString() == "3" || log["_issue"].ToString() == "2" || log["_issue"].ToString() == "1")
                ViewBag.Status = "rdproposalmerge";
        }
        else //舊版研發跟提案分開
        {
            if (log["_issue"] == "3" && log["_rd"] == "3" || log["_issue"] == "3" && log["_rd"] == "1") //判斷rd的審核是否出現
            {
                ViewBag.showrd = "Y";
            }
            else
            {
                ViewBag.showrd = "N";
            }
            //目前狀態，決定資料是否能修改用，預設為issue
            if (log["FlowStatus"].ToString() == "3" || log["FlowStatus"].ToString() == "2" || log["FlowStatus"].ToString() == "1")
                ViewBag.Status = "end";
            else if (log["_proposal"].ToString() == "3" || log["_proposal"].ToString() == "2" || log["_proposal"].ToString() == "1")
                ViewBag.Status = "apply";
            else if (log["_rd"].ToString() == "3")
                ViewBag.Status = "proposal";
            else if (log["_rd"].ToString() == "2" || log["_rd"].ToString() == "1")
                ViewBag.Status = "rdproposal";   //rd審核中
            else if (log["_issue"].ToString() == "3" || log["_issue"].ToString() == "2" || log["_issue"].ToString() == "1")
                ViewBag.Status = "rd";
        }
    }

}
@{
    if (ViewBag.Status == "issue")
    {
        if (log.Count > 0 && log["_issue"].ToString() == "-2")
        {
            ViewBag._popups = string.Empty;
            await Html.PartialAsync("_popups.cshtml");
            if (string.IsNullOrEmpty(ViewBag._popups))
            {
                <script>alert('@Html.Raw(ViewBag._popups)');</script>
            }

        }
    }
}
