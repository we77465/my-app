    Dictionary<string, string> GetSSONo(Microsoft.AspNetCore.Http.IQueryCollection a_q)
    {
        var emp = new Dictionary<string, string>()
        {
            ["lv"] = "",
            ["OU_ID"] = "",
            ["OU_NAME"] = "",
            ["USR_ID"] = "",
            ["NAME"] = "",
            ["MANAGER_LEVEL"] = "",
            ["JOBCODE"] = "",
            ["BRNAME"] = "",
            ["JOBNAME"] = "",
            ["dn"] = "",
            ["DEPTID"] = ""
        };

        string sid = a_q.ContainsKey("sid") ? a_q["sid"].ToString() : "";
        string tid = a_q.ContainsKey("tid") ? a_q["tid"].ToString() : "";
        string bid = a_q.ContainsKey("bid") ? a_q["bid"].ToString() : "";

        if (string.IsNullOrEmpty(sid) && string.IsNullOrEmpty(a_q.ContainsKey("Empid") ? a_q["Empid"].ToString() : ""))
            return emp;

        // Step 1: 打 REST API 取得 USR_ID
        if (!string.IsNullOrEmpty(sid))
        {
            try
            {
                string serverIP = HttpContext.Connection.LocalIpAddress?.ToString() ?? "";
                string url = "https://eip.chb.com.tw/CHB.EIP.WebService/ISAPI/CHBSCWebAPI/CHBSCWebAPI.svc"; //正式機table
                if (serverIP == "10.100.7.188" || serverIP == "10.100.7.186")
                {
                    url = "https://eip.tschb.com/CHB.EIP.WebService/ISAPI/CHBSCWebAPI/CHBSCWebAPI.svc"; //測試機table
                }

                string localIP = HttpContext.Connection.RemoteIpAddress?.ToString() ?? "";
                if (HttpContext.Request.Headers.ContainsKey("X-Forwarded-For"))
                    localIP = HttpContext.Request.Headers["X-Forwarded-For"].ToString().Split(',')[0].Trim();
                else if (HttpContext.Request.Headers.ContainsKey("X-Real-IP"))
                    localIP = HttpContext.Request.Headers["X-Real-IP"].ToString();

                string apiUrl = string.Format("{0}/getUserFullInfo/{1}/{2}/{3}/{4}/{5}",
                    url, sid, localIP, tid, bid, "1");

                using (var client = new HttpClient())
                {
                    client.DefaultRequestHeaders.Add("Accept", "application/json");
                    // ✅ 改用 .Result 同步取得結果
                    string response = client.GetStringAsync(apiUrl).Result;
                    string[] responseArray = System.Text.Json.JsonSerializer.Deserialize<string[]>(response);

                    if (responseArray != null && responseArray.Length > 5)
                    {
                        emp["USR_ID"] = responseArray[1] ?? "";
                        emp["OU_ID"] = responseArray[4] ?? "";
                        emp["OU_NAME"] = responseArray[5] ?? "";
                    }
                }
            }
            catch
            {
                // API 失敗，繼續往下 fallback
            }
        }

        // Step 2: API 沒取到 USR_ID → 查 OG_UAT.NornsUserSession
        if (string.IsNullOrEmpty(emp["USR_ID"]) && !string.IsNullOrEmpty(sid))
        {
            string serverIP = HttpContext.Connection.LocalIpAddress?.ToString() ?? "";
            string tableName = "OG"; //正式機table
            if (serverIP == "10.100.7.188" || serverIP == "10.100.7.186")
            {
                tableName = "OG_UAT"; //測試機table
            }
            try
            {
                string sqlCmd = @"SELECT [USR_ID] FROM [" + tableName + @"].[dbo].[NornsUserSession]
WHERE SESSION_ID=@SID
AND DATEADD(s,@EXPIREDTIME, SESSION_LMT) > GETDATE()";

                using (SqlConnection cnn = new SqlConnection(Configuration["ConnectionStrings:CHBSC"]))
                {
                    cnn.Open();
                    using (SqlCommand cmd = new SqlCommand(sqlCmd, cnn))
                    {
                        cmd.Parameters.AddWithValue("@SID", sid);
                        cmd.Parameters.AddWithValue("@EXPIREDTIME", 68400);
                        using (SqlDataReader dr = cmd.ExecuteReader())
                        {
                            while (dr.Read())
                                emp["USR_ID"] = dr["USR_ID"].ToString();
                        }
                    }
                }
            }
            catch
            {
                // DB 查詢失敗，USR_ID 維持空白
            }
        }
        if (emp["USR_ID"] == "")
        {
            return GetEmpNo(a_q);
        }
        // Step 3: 有 USR_ID 或 Empid → 去 GetEmpNo 查完整資料
        if (!string.IsNullOrEmpty(emp["USR_ID"]) || a_q.ContainsKey("Empid"))
            emp = GetEmpNo(a_q, emp["USR_ID"]);

        return emp;
    }

    Dictionary<string, string> GetEmpNo(Microsoft.AspNetCore.Http.IQueryCollection a_q, string usrId = "203704")
    {
        var emp = new Dictionary<string, string>()
        {
            ["OU_ID"] = "",
            ["OU_NAME"] = "",
            ["USR_ID"] = "",
        };

        //return emp;

        string sid = string.Empty;
        // if (a_q.ContainsKey("sid"))
        //     sid = "(s.SESSION_ID = '" + a_q["sid"].ToString() + "')";
        if (!string.IsNullOrEmpty(emp["USR_ID"]))
        {
            sid = "(STAFF='" + emp["USR_ID"] + "')";
        }
        if (usrId != "")
        {
            sid = "(EMPLOYEE.STAFF='" + usrId + "')";
        }
        if (a_q.ContainsKey("Empid"))
            sid = "(EMPLOYEE.STAFF='" + a_q["Empid"] + "')";

        if (sid == string.Empty)
        {
            return emp;
        }
        string sqlstring = @"
SELECT
EMPLOYEE.MANAGER_LEVEL,
UNIT.OU_ID,
UNIT.OU_NAME,
EMPLOYEE.STAFF AS USR_ID,
EMPLOYEE.NAME,
DATAEDIT.發明人員編,
DATAEDIT.資料編輯員編,
DATAEDIT.發明人單位
FROM
chb_pub.dbo.EMPLOYEE
JOIN CHBSC.dbo.SC_ORG_UNIT AS UNIT ON EMPLOYEE.BRNO = UNIT.OU_ID collate Chinese_Taiwan_Stroke_CI_AS
LEFT OUTER JOIN iom.dbo.FinTechPatnet_DataEdit AS DATAEDIT ON DATAEDIT.DocNo = '" + ViewBag.docno +
            "' WHERE" + sid;
        using (SqlConnection conn = new SqlConnection(Configuration["ConnectionStrings:by"]))
        {
            conn.Open();
            using (SqlCommand command = new SqlCommand(sqlstring, conn))
            {
                //empid = (command.ExecuteScalar() == null) ? string.Empty : command.ExecuteScalar().ToString();
                var r = command.ExecuteReader();
                string Famin = "N";
                while (r.Read())
                {
                    if (r["發明人員編"].ToString() == r["USR_ID"].ToString() || r["資料編輯員編"].ToString() == r["USR_ID"].ToString())
                        Famin = "Y"; //起案者、發明人可編輯該案件
                    if (CheckBM(r["USR_ID"].ToString(), "Fintech_Dep_Mgr") || CheckBM(r["USR_ID"].ToString(), "Fintech_Admin"))
                    {
                        if (r["OU_ID"].ToString().PadRight(6, '0') == r["發明人單位"].ToString())
                            Famin = "Y"; //各處窗口、數金管理人可編輯該處案件
                    }

                    emp = new Dictionary<string, string>()
                    {
                        ["lv"] = r["MANAGER_LEVEL"].ToString(),
                        ["OU_ID"] = r["OU_ID"].ToString(),
                        ["OU_NAME"] = r["OU_NAME"].ToString(),
                        ["USR_ID"] = r["USR_ID"].ToString(),
                        ["NAME"] = r["NAME"].ToString(),
                        ["FAMIN"] = Famin
                    };
                }
            }
            conn.Close();
        }
        return emp;
    }



