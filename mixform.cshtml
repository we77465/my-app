    <input type="hidden" name="brno" value=@ViewBag.ubrno>
    <input type="hidden" name="fintechver" value=@ViewBag.ver>

    @if (log.Count != 0)
    {
        if (ViewBag.ver == "1") //新版研發跟提案合併
