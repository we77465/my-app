                                }
                            }
                        }
                    }
                }
            }
        }
        else
        {
            error = checkField("研發前檢索", error, Request.Form);
            error = checkField("重大研發成本案件", error, Request.Form);
            error = checkField("全新技術", error, Request.Form);
            if (Request.Form["重大研發成本案件"].ToString() == "N" || Request.Form["全新技術"].ToString() == "N")
            {
                if (Request.Form["研發前檢索"].ToString() != "N" && error == false)
                {
                    error = true;
                    WriteLiteral("<script>alert('送出失敗：重大研發成本案件或全新技術為否時，「研發前檢索」欄位必為否');</script>");
                }
            }
            if (Request.Form["重大研發成本案件"].ToString() == "Y" && Request.Form["全新技術"].ToString() == "Y" && Request.Form["研發前檢索"].ToString() == "N" && error == false)
            {
                error = true;
                WriteLiteral("<script>alert('送出失敗：重大研發成本案件及全新技術為是時，「研發前檢索」欄位必為是');</script>");
            }
            if (Request.Form["研發前檢索"].ToString() == "Y" && Request.Form.Files["研發前檢索檔"] == null && error == false)
            {
                error = true;
                WriteLiteral("<script>alert('送出失敗：研發前檢索選是，應完成檢索資料上傳');</script>");
            }
        }
        return error;
    }
    bool checkField(string FieldName, bool error, Microsoft.AspNetCore.Http.IFormCollection iform)
    {
        if (error == false)
        {
            if (string.IsNullOrEmpty(iform[FieldName].ToString()))
            {
                error = true;
                WriteLiteral("<script>alert('儲存失敗：「" + @FieldName + "」欄位必填');</script>");
            }
        }
        return error;
    }
    Boolean CheckBM(string EmpID, string RoleID)
    {
        using (SqlConnection cnn = new SqlConnection(Configuration["ConnectionStrings:by"]))
        {
            cnn.Open();
            string SqlCmd = "SELECT 1 FROM CHBSC..SC_ROL_USR WHERE (USR_ID =@EmpID) and (ROL_ID=@RoleID)"; //查使用者角色
            using (SqlCommand cmd = new SqlCommand(SqlCmd, cnn))
            {
                cmd.Parameters.AddWithValue("@EmpID", EmpID);
                cmd.Parameters.AddWithValue("@RoleID", RoleID);
                return cmd.ExecuteReader().HasRows;
            }
        }
    }
    void newLine(Microsoft.AspNetCore.Http.IFormCollection iform, string AddorDel)
    {
        ViewBag.rdLine = string.IsNullOrEmpty(iform["研發說明筆數"].ToString()) ? "1" : iform["研發說明筆數"].ToString();
        if (AddorDel == "Add")
        {
            if (ViewBag.rdLine == "2")
                ViewBag.rdLine = "3";
            else
                ViewBag.rdLine = "2";
        }
        if (AddorDel == "Del")  //20240410 數金處 薛伃庭 研發說明新增刪除一筆功能
        {
            if (ViewBag.rdLine == "3")
                ViewBag.rdLine = "2";
            else
                ViewBag.rdLine = "1";
        }
    }

