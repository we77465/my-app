            {
                <input type="hidden" name="pay">
            }
        }
        else //舊版研發跟提案分開
        {
            if (log["_issue"] == "3" && ViewBag.famin == "Y" || log["_issue"] == "3" && string.Compare(log["_rd"], "0") > 0)//研發
                                                                                                                            @await Html.PartialAsync("_rd.cshtml")

                if (log["_rd"] == "3" && ViewBag.famin == "Y" || log["_rd"] == "3" && string.Compare(log["_proposal"], "0") > 0)//提案
                                                                                                                                @await Html.PartialAsync("_proposal.cshtml")

                    if (log["_proposal"] == "3" && ViewBag.famin == "Y" || log["_proposal"] == "3" && string.Compare(log["FlowStatus"], "0") > 0)//申請/審核/領證
                                                                                                                                                 @await Html.PartialAsync("_apply.cshtml")

                        @*if (log["FlowStatus"] == "3" && ViewBag.famin == "Y" || log["FlowStatus"] == "3" && string.Compare(log["_pay"], "0") > 0)//屆期續存評估表
                @await Html.PartialAsync("_pay.cshtml")*@

                        if (log["_issue"] != "3")
                        {
                            <input type="hidden" name="issue">
                        }
                        else if (log["_rd"] != "3")
                        {
                            <input type="hidden" name="rd">
                        }
                        else if (log["_proposal"] != "3")
                        {
                            <input type="hidden" name="proposal">
                        }
                        else if (log["FlowStatus"] != "3")
                        {
                            <input type="hidden" name="FlowStatus">
                        }
                        else if (log["_pay"] != "3")
                        {
                            <input type="hidden" name="pay">
                        }
        }
    }

    @if (log.Count == 0 || (mfs.Replace("3", "") == string.Empty && mfs != "3333" && ViewBag.famin == "Y") || (mfs.Replace("3", "") == "-2" && ViewBag.famin == "Y")) //新的提案 or 其中一個階段完成放行(3)，但還沒結案 or 其中一個階段剛儲存(-2)
    {
        <input type="submit" value="儲存" onclick="topFunction(this)" />
        if (mfs.StartsWith("333") && log["FlowStatus"] != "3")    //20240410 數金處 薛伃庭 流程在「申請/審核/領證」時，專利申請狀態為《已核准》、《放棄答辯》、《放棄再審》，才能送負責人核可
        {
            if (ViewBag.ver == "1") //新版研發跟提案合併
            {
                if (ViewBag.data[0]["對外公開"] == "Y" && ViewBag.data[0]["公開目的"] == "A")
                {
                    if (ViewBag.data[0]["核准日"] != "" || ViewBag.data[0]["放棄答辯日"] != "" || ViewBag.data[0]["再審"] == "N")
                    {
                        <input type="submit" value="儲存並送負責人核可" onclick="topFunction(this)" style="@(log.Count > 0 ? "" : "display:none")" />
                    }
                }
                else
                {
                    <input type="submit" value="儲存並送負責人核可" onclick="topFunction(this)" style="@(log.Count > 0 ? "" : "display:none")" />
                }
            }
            else //舊版研發跟提案分開
            {
                if (ViewBag.data[0]["核准日"] != "" || ViewBag.data[0]["放棄答辯日"] != "" || ViewBag.data[0]["再審"] == "N")
                {
                    <input type="submit" value="儲存並送負責人核可" onclick="topFunction(this)" style="@(log.Count > 0 ? "" : "display:none")" />
                }
            }
        }
        else
        {
            <input type="submit" value="儲存並送負責人核可" onclick="topFunction(this)" style="@(log.Count > 0 ? "" : "display:none")" />
        }
        ViewBag.sign = "N";
        if (log.Count != 0)
        {
            if (log["_issue"] != "3") //20240410 數金處 薛伃庭 經任一主管放行後的案件無法刪除
            {
                <input type="submit" value="刪除" onclick="topFunction(this)" />
            }
        }
    }
    else if (mfs != "3333") //還沒結案，帶負責人放行 or 待主管放行
    {
        ViewBag.sign = "Y";
        if (mfs.Contains("1"))
        {
            if (mfs == "1" || mfs == "31")
            {
                if (who["lv"] == "00" || who["lv"] == "05" || who["lv"] == "09")
                {
                    <input type="submit" value="放行" onclick="topFunction(this)" />
                    <input type="submit" value="退回修改" onclick="topFunction(this)" />
                    ViewBag.sign = "Y";
                }
            }
            else if (who["lv"] == "00" || who["lv"] == "05" || who["lv"] == "09")
            {
                <input type="submit" value="送主管核可" onclick="topFunction(this)" />
                <input type="submit" value="退回修改" onclick="topFunction(this)" />
                ViewBag.sign = "Y";
            }
        }
        else if (mfs.Contains("-") && ViewBag.famin == "Y") //還在申請人編輯狀態(-2)
        {
            <input type="submit" value="儲存" onclick="topFunction(this)" />
            if (log["_proposal"] == "3" && log["FlowStatus"] != "3")    //20240410 數金處 薛伃庭 流程在「申請/審核/領證」時，專利申請狀態為《已核准》、《放棄答辯》、《放棄再審》，才能送負責人核可
            {
                if (ViewBag.ver == "1") //新版研發跟提案合併
                {
                    if (ViewBag.data[0]["對外公開"] == "Y" && ViewBag.data[0]["公開目的"] == "A")
                    {
                        if (ViewBag.data[0]["核准日"] != "" || ViewBag.data[0]["放棄答辯日"] != "" || ViewBag.data[0]["再審"] == "N")
                        {
                            <input type="submit" value="儲存並送負責人核可" onclick="topFunction(this)" style="@(log.Count > 0 ? "" : "display:none")" />
                        }
                    }
                    else
                    {
                        <input type="submit" value="儲存並送負責人核可" onclick="topFunction(this)" style="@(log.Count > 0 ? "" : "display:none")" />
                    }
                }
                else //舊版研發跟提案分開
                {
                    if (ViewBag.data[0]["核准日"] != "" || ViewBag.data[0]["放棄答辯日"] != "" || ViewBag.data[0]["再審"] == "N")
                    {
                        <input type="submit" value="儲存並送負責人核可" onclick="topFunction(this)" />
                    }
                }

            }
            else
            {
                <input type="submit" value="儲存並送負責人核可" onclick="topFunction(this)" />

            }
            if (log["_issue"] != "3")   //20240410 數金處 薛伃庭 經任一主管放行後的案件無法刪除
            {
                <input type="submit" value="刪除" onclick="topFunction(this)" />
            }
            ViewBag.sign = "N";
        }
        else
        {
            if ((who["lv"] == "00" && (mfs.Replace("3", "") != string.Empty) && (!mfs.Contains("-"))) || (who["lv"] == "05" && (mfs.Replace("3", "") != string.Empty) && (!mfs.Contains("-"))))
            {
                <input type="submit" value="放行" onclick="topFunction(this)" />
                <input type="submit" value="退回修改" onclick="topFunction(this)" />
                ViewBag.sign = "Y";
            }
        }
    }
    <input type="button" onclick="history.go(-1);" value="回前頁">
    <p />

    @if (string.IsNullOrEmpty(ViewBag._checks) == false)
    {
        //foreach (var checkMsg in ViewBag._checks.Split('\n'))
        {
            <script>alert('@Html.Raw(ViewBag._checks)');</script>
        }
    }

    @Html.Hidden("hHtml")
</form>

<script>
    // Get the button
    let mybutton = document.getElementById("myBtn");

    // When the user scrolls down 20px from the top of the document, show the button
    window.onscroll = function () { scrollFunction() };

    function scrollFunction() {
        mybutton.style.display = "block";
    }

    function topFunction(action) {
        document.getElementById("hHtml").value = action.value;
    }
    function handleChange(src) {
        var display;
        switch (src.value) {
            case 'N':
                display = "none";
