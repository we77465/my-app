<form method="post" enctype="multipart/form-data">
    @if (log.Count == 0 || (mfs.Replace("3", "") == string.Empty && mfs != "3333" && ViewBag.famin == "Y") || (mfs.Replace("3", "") == "-2" && ViewBag.famin == "Y"))
