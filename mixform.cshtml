    string filename(string filesname)
    {
        var fn = filesname;
        switch (filesname)
        {
            //發想
            case "研發前檢索檔": fn = "A02000"; break;
            case "迴避設計評估報告": fn = "A10000"; break;
            //研發
            case "提案構想書等研發紀錄": fn = "A08000"; break;
            //提案
            case "提案揭露書": fn = "A01000"; break;
            case "提案第X次補充資料": fn = "A0300X"; break;
            case "其他補充文件": fn = "A09000"; break;
            //申請
